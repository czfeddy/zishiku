<view class="page-shell share-page">
  <view wx:if="{{content.isMomentsPost}}" class="helper-banner">
    <view class="helper-banner__eyebrow">朋友圈素材助手</view>
    <view class="helper-banner__title">文案复制、图片保存后，请去微信朋友圈手动发布</view>
    <view class="helper-banner__desc">本页不会再引导右上角分享，避免发布成链接卡片。</view>
  </view>

  <view class="card">
    <image wx:if="{{content.shareImageUrl}}" class="card__cover" src="{{content.shareImageUrl}}" mode="aspectFill" />
    <view class="card__body">
      <view class="card__eyebrow">{{content.isMomentsPost ? '朋友圈素材' : '分享文章'}}</view>
      <view class="card__title">{{content.title}}</view>
      <view class="card__summary">{{content.summary}}</view>

      <view wx:if="{{content.isMomentsPost}}" class="moments-box">
        <view wx:if="{{content.momentsText}}" class="moments-box__section">
          <view class="moments-box__label">待发布文案</view>
          <view class="moments-box__text">{{content.momentsText}}</view>
        </view>

        <view wx:if="{{content.momentsImages.length}}" class="moments-box__section">
          <view class="moments-box__label">待发布图片</view>
          <view class="moments-gallery">
            <image
              wx:for="{{content.momentsImages}}"
              wx:key="url"
              class="moments-gallery__item"
              src="{{item.url}}"
              mode="aspectFill"
            />
          </view>
        </view>
      </view>

      <view wx:if="{{!content.isMomentsPost && content.body}}" class="card__content">{{content.body}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="status status--info">正在同步内容...</view>
  <view wx:if="{{preparingMoments}}" class="status status--info">{{prepareStatus}}</view>
  <view wx:if="{{prepareStatus && !preparingMoments}}" class="status status--success">{{prepareStatus}}</view>
  <view wx:if="{{autoOpening && !error}}" class="status status--info">正在打开文章...</view>
  <view wx:if="{{error}}" class="status status--warn">{{error}}</view>

  <view wx:if="{{content.isMomentsPost && prepareStatus && !preparingMoments}}" class="publish-steps">
    <view class="publish-steps__title">下一步</view>
    <view class="publish-steps__item">1. 返回微信首页</view>
    <view class="publish-steps__item">2. 进入“发现 - 朋友圈”</view>
    <view class="publish-steps__item">3. 点击右上角相机，选择刚保存的图片</view>
    <view class="publish-steps__item">4. 粘贴文案后发布</view>
  </view>

  <view class="actions">
    <button
      wx:if="{{content.isMomentsPost}}"
      class="primary-btn"
      type="primary"
      loading="{{preparingMoments}}"
      bindtap="handlePrepareMoments"
    >
      重新准备素材
    </button>
    <button class="secondary-btn" bindtap="handleShowPublishGuide">
      {{content.isMomentsPost ? '查看手动发布步骤' : '查看分享卡片方法'}}
    </button>
    <button class="ghost-btn" bindtap="handleOpenWebview">查看原文</button>
    <button wx:if="{{error}}" class="ghost-btn" bindtap="handleRetry">重新加载</button>
  </view>
</view>
