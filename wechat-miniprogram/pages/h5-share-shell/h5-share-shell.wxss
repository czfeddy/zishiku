.share-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f4f8ff 0%, #eef3f8 100%);
}

.helper-banner {
  margin-bottom: 24rpx;
  padding: 28rpx 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #153d7a 0%, #2c69e8 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(31, 87, 191, 0.18);
}

.helper-banner__eyebrow {
  font-size: 23rpx;
  line-height: 1.6;
  opacity: 0.82;
}

.helper-banner__title {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
}

.helper-banner__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.88;
}

.card {
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(16, 35, 59, 0.08);
}

.card__cover {
  display: block;
  width: 100%;
  height: 320rpx;
  background: #eef3f8;
}

.card__body {
  padding: 28rpx 24rpx;
}

.card__eyebrow {
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 600;
  color: #1f57bf;
}

.card__title {
  margin-top: 8rpx;
  font-size: 36rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #10233b;
}

.card__summary {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4f6077;
}

.card__content {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #5b6677;
  white-space: pre-wrap;
  word-break: break-word;
}

.moments-box {
  margin-top: 24rpx;
  border-radius: 24rpx;
  background: #f7faff;
  padding: 24rpx 20rpx;
}

.moments-box__section + .moments-box__section {
  margin-top: 20rpx;
}

.moments-box__label {
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 600;
  color: #1f57bf;
}

.moments-box__text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #24364a;
  white-space: pre-wrap;
  word-break: break-word;
}

.moments-gallery {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.moments-gallery__item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  background: #e8eef6;
}

.status {
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  font-size: 25rpx;
  line-height: 1.6;
}

.status--info {
  background: #eef5ff;
  color: #2257b5;
}

.status--success {
  background: #edf9f1;
  color: #1d7a41;
}

.status--warn {
  background: #fff4e8;
  color: #a85a0a;
}

.publish-steps {
  margin-top: 22rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(16, 35, 59, 0.06);
}

.publish-steps__title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #10233b;
}

.publish-steps__item {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #4f6077;
}

.actions {
  margin-top: 24rpx;
}

.primary-btn,
.secondary-btn,
.ghost-btn {
  margin-top: 16rpx;
  border-radius: 999rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #1e5fe5 0%, #5e95ff 100%);
}

.secondary-btn {
  color: #1f57bf;
  background: #edf4ff;
}

.ghost-btn {
  color: #6b7280;
  background: #f4f6f8;
}
