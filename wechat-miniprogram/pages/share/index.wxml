<view class="redirect-shell">
  <view class="redirect-card">
    <view class="redirect-title">正在进入最新分享页</view>
    <view class="redirect-desc" wx:if="{{redirecting}}">
      当前链接是旧版分享入口，系统会自动跳转到最新的小程序分享壳。
    </view>
    <view class="redirect-error" wx:if="{{error}}">{{error}}</view>
  </view>
</view>
