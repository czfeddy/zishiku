.redirect-shell {
  min-height: 100vh;
  padding: 48rpx 24rpx;
  box-sizing: border-box;
}

.redirect-card {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(16, 35, 59, 0.08);
  padding: 28rpx 24rpx;
}

.redirect-title {
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #10233b;
}

.redirect-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4f6077;
}

.redirect-error {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff4e8;
  color: #a85a0a;
  font-size: 25rpx;
  line-height: 1.6;
}
