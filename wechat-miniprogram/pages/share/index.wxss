.share-page {
  padding: 32rpx 24rpx 48rpx;
}

.hero {
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #103f91 0%, #2f74ff 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(30, 78, 173, 0.18);
}

.hero__eyebrow {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  opacity: 0.82;
}

.hero__title {
  margin-top: 14rpx;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
}

.hero__desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  opacity: 0.92;
}

.card {
  margin-top: 26rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(16, 35, 59, 0.08);
}

.card__label {
  padding: 22rpx 24rpx 0;
  color: #4f6b95;
  font-size: 24rpx;
}

.card__image {
  width: calc(100% - 48rpx);
  height: 280rpx;
  margin: 18rpx 24rpx 0;
  border-radius: 22rpx;
  background: #dbe7ff;
}

.card__body {
  padding: 24rpx;
}

.card__title {
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #10233b;
}

.card__summary {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4f6077;
}

.status {
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  font-size: 25rpx;
}

.status--info {
  background: #eef5ff;
  color: #2257b5;
}

.status--warn {
  background: #fff4e8;
  color: #a85a0a;
}

.info-list {
  margin-top: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.85);
}

.info-list__item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(16, 35, 59, 0.08);
}

.info-list__item:last-child {
  border-bottom: 0;
}

.info-list__label {
  display: block;
  font-size: 24rpx;
  color: #607491;
}

.info-list__value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #10233b;
}

.info-list__value--small {
  font-size: 24rpx;
  word-break: break-all;
}

.actions {
  margin-top: 24rpx;
}

.primary-btn,
.secondary-btn,
.ghost-btn {
  margin-top: 16rpx;
  border-radius: 999rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #1e5fe5 0%, #5e95ff 100%);
}

.secondary-btn {
  color: #1f57bf;
  background: #edf4ff;
}

.ghost-btn {
  color: #6b7280;
  background: #f4f6f8;
}

.notes {
  margin-top: 26rpx;
  padding: 28rpx 26rpx;
  border-radius: 24rpx;
  background: rgba(16, 35, 59, 0.88);
  color: #f7fbff;
}

.notes__title {
  font-size: 28rpx;
  font-weight: 700;
}

.notes__item {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(247, 251, 255, 0.86);
}
