# WeChat official account config for JS-SDK signature
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# WeChat Pay v3 config for H5 recharge
# If omitted, WECHAT_PAY_APP_ID falls back to WECHAT_APP_ID.
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=

# Alipay WAP pay config for H5 recharge
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_NOTIFY_URL=
ALIPAY_GATEWAY_HOST=openapi.alipay.com
ALIPAY_GATEWAY_PATH=/gateway.do

# Shared cache for access_token and jsapi_ticket.
# Use one Redis for all subdomains/products under the same AppID.
WECHAT_REDIS_URL=redis://redis:6379/0
WECHAT_CACHE_PREFIX=wechat:jsapi

# Primary site domain, without protocol or path
DOMAIN=

# Exact hostnames that are configured in WeChat "JS interface security domain"
# Example: a.example.com,b.example.com
WECHAT_ALLOWED_HOSTS=

# Exact hostnames allowed in share links. Defaults to WECHAT_ALLOWED_HOSTS.
WECHAT_SHARE_ALLOWED_HOSTS=

# Site metadata
SITE_NAME=知识库
SITE_SHORT_NAME=知识库
COMPANY_NAME=
CONTACT_EMAIL=
CONTACT_PHONE=
DEFAULT_CARD_NAME=
DEFAULT_CARD_ROLE=资深金融顾问
DEFAULT_CARD_DESCRIPTION=
DEFAULT_CARD_AVATAR_URL=
DEFAULT_CARD_WECHAT=
ICP_NUMBER=
PUBLIC_SECURITY_NUMBER=
PUBLIC_SECURITY_URL=

# Default share image, should be an absolute https URL
DEFAULT_SHARE_IMAGE=

# Mini program share-shell config for auto-generated moments card links
MINI_PROGRAM_NAME=
MINI_PROGRAM_APP_ID=
MINI_PROGRAM_APP_SECRET=
MINI_PROGRAM_ORIGINAL_ID=
MINI_PROGRAM_SHARE_PAGE=/pages/h5-share-shell/h5-share-shell
MINI_PROGRAM_ENV_VERSION=release
MINI_PROGRAM_URL_LINK_EXPIRE_DAYS=30
